PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/bricouly
JWT_SECRET=your-secret-key-here
JWT_EXPIRE=30d
FRONTEND_URL=http://localhost:5173

# Google OAuth (optional)
# 1. Go to https://console.cloud.google.com
# 2. Create OAuth 2.0 credentials
# 3. Add authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth (optional)
# 1. Go to https://developers.facebook.com
# 2. Create an app with Facebook Login product
# 3. Add Valid OAuth Redirect URI: http://localhost:3001/api/auth/facebook/callback
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
